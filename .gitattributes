# Fins de ligne normalisees en LF dans le depot -> shebangs et scripts corrects
# sur Linux/Kali (un CRLF dans un '#!/usr/bin/env python3' casse l'interpreteur).
* text=auto eol=lf
*.py text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
